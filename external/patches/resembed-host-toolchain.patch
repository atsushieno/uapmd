diff --git a/Generator/CMakeLists.txt b/Generator/CMakeLists.txt
index c31d0f1..5bc8e51 100644
--- a/Generator/CMakeLists.txt
+++ b/Generator/CMakeLists.txt
@@ -10,6 +10,7 @@ if(PROJECT_NAME)
 
     set(_res_embed_configure_cmd ${CMAKE_COMMAND})
     set(_res_embed_build_cmd ${CMAKE_COMMAND})
+    set(_res_embed_configure_args "${CMAKE_CURRENT_SOURCE_DIR}" -DCMAKE_BUILD_TYPE=Release)
     if(RES_EMBED_HOST_CC OR RES_EMBED_HOST_CXX)
         set(_res_embed_configure_cmd ${CMAKE_COMMAND} -E env)
         if(RES_EMBED_HOST_CC)
@@ -17,16 +18,33 @@ if(PROJECT_NAME)
         endif()
         if(RES_EMBED_HOST_CXX)
             list(APPEND _res_embed_configure_cmd "CXX=${RES_EMBED_HOST_CXX}")
+            list(APPEND _res_embed_configure_args "-DCMAKE_CXX_COMPILER=${RES_EMBED_HOST_CXX}")
+        endif()
+        if(RES_EMBED_HOST_CC)
+            list(APPEND _res_embed_configure_args "-DCMAKE_C_COMPILER=${RES_EMBED_HOST_CC}")
         endif()
         list(APPEND _res_embed_configure_cmd ${CMAKE_COMMAND})
         set(_res_embed_build_cmd ${_res_embed_configure_cmd})
     endif()
 
+    # When the parent project is configured with a cross-compiling toolchain
+    # (e.g. emcmake), CMAKE_TOOLCHAIN_FILE propagates into this sub-configure
+    # and forces CMake to pick em++ despite the CC/CXX overrides above.
+    # Explicitly clear it so the host compiler is honored.
+    if(CMAKE_TOOLCHAIN_FILE)
+        list(APPEND _res_embed_configure_args "-DCMAKE_TOOLCHAIN_FILE=")
+    endif()
+
+    if(NOT RES_EMBED_HOST_CC AND NOT RES_EMBED_HOST_CXX)
+        # No explicit host compiler was provided; fall back to the default
+        # generator behavior but still ensure we don't inherit a cross toolchain.
+        set(_res_embed_build_cmd ${CMAKE_COMMAND})
+    endif()
+
     message(STATUS "Building ResEmbed Generator")
 
     execute_process(
-        COMMAND ${_res_embed_configure_cmd}
-            "${CMAKE_CURRENT_SOURCE_DIR}"
-            -DCMAKE_BUILD_TYPE=Release
+        COMMAND ${_res_embed_configure_cmd} ${_res_embed_configure_args}
         WORKING_DIRECTORY "${host_dir}"
         OUTPUT_QUIET
         RESULT_VARIABLE result)
