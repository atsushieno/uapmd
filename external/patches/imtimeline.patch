+namespace {
+
+ImU32 blendColor(ImU32 base, ImU32 overlay)
+{
+    ImVec4 baseColor = ImGui::ColorConvertU32ToFloat4(base);
+    ImVec4 overlayColor = ImGui::ColorConvertU32ToFloat4(overlay);
+    const float alpha = overlayColor.w;
+    ImVec4 mixed;
+    mixed.x = baseColor.x * (1.0f - alpha) + overlayColor.x * alpha;
+    mixed.y = baseColor.y * (1.0f - alpha) + overlayColor.y * alpha;
+    mixed.z = baseColor.z * (1.0f - alpha) + overlayColor.z * alpha;
+    mixed.w = baseColor.w;
+    return ImGui::ColorConvertFloat4ToU32(mixed);
+}
+
+} // namespace
